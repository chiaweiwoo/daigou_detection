DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Calibration uses a stronger model as an independent judge.
# DeepSeek-V3 (deepseek-chat) is the recommended default.
CALIBRATION_MODEL=deepseek-chat
CALIBRATION_SAMPLE_HIGH=15
CALIBRATION_SAMPLE_MED=10
CALIBRATION_SAMPLE_LOW=5
